<script>
document.addEventListener('DOMContentLoaded', function() {
    // Aplicar dark mode siempre, sin importar si hay topbar
    const isDark = localStorage.getItem('darkMode') === 'true';
    if(isDark) document.documentElement.classList.add('dark-mode');

    const topbar = document.querySelector('.topbar');
    if(topbar) {
        const extraBtns = document.createElement('div');
        extraBtns.style.cssText = "display:flex; gap:10px; margin-left:auto; align-items:center;";
        
        // Quitar margen automático a otros elementos para que los botones queden pegados a la derecha
        const mlAuto = topbar.querySelector('[style*="margin-left: auto"]');
        if(mlAuto) mlAuto.style.marginLeft = '0';
        
        // Boton Dark Mode
        const btnDark = document.createElement('button');
        btnDark.className = "btn-sec";
        btnDark.style.cssText = "padding: 5px 10px; font-size: 16px; border-radius: 8px; border: 1px solid #ddd; background: #fff; cursor: pointer; display: flex; align-items: center; justify-content: center;";
        btnDark.title = "Modo Oscuro / Claro";
        
        // Boton Fullscreen
        const btnFull = document.createElement('button');
        btnFull.className = "btn-sec";
        btnFull.style.cssText = "padding: 5px 10px; font-size: 16px; border-radius: 8px; border: 1px solid #ddd; background: #fff; cursor: pointer; display: flex; align-items: center; justify-content: center;";
        btnFull.title = "Pantalla Completa";

        extraBtns.appendChild(btnFull);
        extraBtns.appendChild(btnDark);
        topbar.appendChild(extraBtns);

        btnDark.innerHTML = isDark ? "☀️" : "🌙";

        btnDark.onclick = () => {
            document.documentElement.classList.toggle('dark-mode');
            const darkEnabled = document.documentElement.classList.contains('dark-mode');
            localStorage.setItem('darkMode', darkEnabled);
            btnDark.innerHTML = darkEnabled ? "☀️" : "🌙";
        };

        // Lógica Fullscreen
        btnFull.innerHTML = document.fullscreenElement ? "🗗" : "⛶";
        btnFull.onclick = () => {
            if (!document.fullscreenElement) {
                document.documentElement.requestFullscreen().catch(err => {
                    console.log(`Error fullscreen: ${err.message}`);
                });
            } else {
                document.exitFullscreen();
            }
        };
        
        document.addEventListener('fullscreenchange', () => {
            btnFull.innerHTML = document.fullscreenElement ? "🗗" : "⛶";
        });
    }
});
</script>