<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="stylesheet" href="/css/responsive.css">
  <title>YJMRepair — Cambiar contraseña</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('partials/sidebar-admin', { user, active: 'password' }) %>
<div class="main">
  <div class="topbar">
    <div class="topbar-title">Cambiar contraseña</div>
  </div>
  <div class="content">
    <% if(typeof msg !== 'undefined') { %>
      <div class="alert-success"><%= msg %></div>
    <% } %>
    <div class="card" style="max-width:420px">
      <div class="card-hd"><span>Cambiar clave de <%= objetivo.nombre %></span></div>
      <form action="/admin/usuarios/actualizar-password" method="POST" style="display:flex;flex-direction:column;gap:14px">
        <input type="hidden" name="id" value="<%= objetivo.id %>">
        <div class="field">
          <label>Nueva contraseña</label>
          <input type="password" name="password" placeholder="Mínimo 6 caracteres" required minlength="6">
        </div>
        <div class="field">
          <label>Repetir contraseña</label>
          <input type="password" name="password2" placeholder="Repetir contraseña" required minlength="6">
        </div>
        <div style="display:flex;gap:8px">
          <a href="/admin/usuarios" class="btn-sec">Cancelar</a>
          <button type="submit" class="btn-primary">Guardar nueva contraseña</button>
        </div>
      </form>
    </div>
  </div>
</div>
</body>
</html>
